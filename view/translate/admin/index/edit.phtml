<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Translator\Form\TranslateForm $form
 * @var \Translator\Api\Representation\TranslateRepresentation $translate
 * @var \Translator\Api\Representation\TranslateRepresentation $resource
 */

$translation = $translate;

$plugins = $this->getHelperPluginManager();
$translate = $plugins->get('translate');
$assetUrl = $plugins->get('assetUrl');

$this->htmlElement('body')->appendAttribute('class', 'translates edit');

$this->headLink()
    ->appendStylesheet($assetUrl('css/translator-admin.css', 'Translator'));

$deleteButton = $translate->userIsAllowed('delete')
    ? '<a href="#" class="delete button">' . $translate('Delete') . '</a>'
    : null;
?>

<?= $this->pageTitle($translation->displayTitle(), 1, $translate('Translations'), $translate('Edit')) ?>

<?php $this->trigger('view.edit.before'); ?>

<?= $this->partial('translate/admin/index/form', [
    'form' => $form,
    'translate' => $translation,
    'resource' => $translation,
    'action' => 'edit',
    'submitLabel' => $translate('Save'),
    'deleteButton' => $deleteButton,
]) ?>

<?= $this->deleteConfirm($translation, 'translate') ?>

<?php $this->trigger('view.edit.after'); ?>
