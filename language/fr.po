#: data/scripts/upgrade.php:38 Module.php:149
#, php-format
msgid "The module %1$s should be upgraded to version %2$s or later."
msgstr "Le module %1$s doit être mis à niveau à la version %2$s ou supérieure."

#: Module.php:206
msgid ""
"Fill your DeepL api key, then set languages to translate in {link}main "
"settings{link_end}."
msgstr ""
"Indiquez votre clé api DeepL, puis définissez les langues à traduire dans "
"{link}les paramètres généraux{link_end}."

#: Module.php:878
msgid "The following source languages are not supported currently: {list}."
msgstr ""
"Les langues sources suivantes ne sont pas prises en charge actuellement : "
"{list}."

#: Module.php:884
msgid "The following target languages are not supported currently: {list}."
msgstr ""
"Les langues cibles suivantes ne sont pas prises en charge actuellement : "
"{list}."

#: src/Form/SettingsFieldset.php:14
msgid "Internationalisation: Resources"
msgstr "Internationalisation: Ressources"

#: src/Form/SettingsFieldset.php:17
msgid "Internationalisation: resources"
msgstr "Internationalisation : ressources"

#: src/Form/SettingsFieldset.php:31
msgid "Default language for values without any one"
msgstr "Langue par défaut pour les valeurs sans"

#: src/Form/SettingsFieldset.php:32
msgid ""
"The language should be a 2-letter iso code (ISO 3166-1) supported by the "
"translation service."
msgstr ""
"La langue doit être un code ISO à 2 lettres (ISO 3166-1) pris en charge par "
"le service de traduction."

#: src/Form/SettingsFieldset.php:35
msgid "Automatic"
msgstr "Automatique"

#: src/Form/SettingsFieldset.php:36
msgid "Skip"
msgstr "Ignorer"

#: src/Form/SettingsFieldset.php:43
msgid "Select language…"
msgstr "Choisir la langue…"

#: src/Form/SettingsFieldset.php:51
msgid "Target languages or pairs of languages to translate"
msgstr "Langues cibles ou paires de langues à traduire"

#: src/Form/SettingsFieldset.php:52
msgid ""
"The source language will be automatically defined when not set. For pairs, "
"separate source and target with a \"=\", one by line. The source language "
"should be a 2-letter iso code (ISO 3166-1) supported by the translation "
"service. The target language may have the localization code if supported."
msgstr ""
"La langue source sera automatiquement définie si elle n’est pas indiquée. "
"Pour les paires, séparez la source et la cible par un « = », une ligne à la "
"fois. La langue source doit être un code ISO à 2 lettres (ISO 3166-1) pris "
"en charge par le service de traduction. La langue cible peut comporter le "
"code de localisation s’il est pris en charge."

#: src/Form/SettingsFieldset.php:75
msgid "Properties to translate"
msgstr "Propriétés à traduire"

#: src/Form/SettingsFieldset.php:76
msgid ""
"Only literal data are translated, not numeric values, resources, uri, or "
"other data. It is recommended to remove big fields from the list of "
"properties, in particular extracted text."
msgstr ""
"Seules les données littérales sont traduites, pas les valeurs numériques, ni "
"les ressources, ni les uri ou d’autres données. Il est recommandé de "
"supprimer les champs avec de grandes valeurs de la liste des propriétés, en "
"particulier le texte extrait."

#: src/Form/SettingsFieldset.php:80 src/Form/SettingsFieldset.php:110
msgid "Resource metadata"
msgstr "Métadonnées de la ressource"

#: src/Form/SettingsFieldset.php:82
msgid "All properties"
msgstr "Toutes les propriétés"

#: src/Form/SettingsFieldset.php:83 src/Form/SettingsFieldset.php:115
msgid "All properties less or equal to 500 characters"
msgstr "Propriétés inférieures ou égales à 500 caractères"

#: src/Form/SettingsFieldset.php:84 src/Form/SettingsFieldset.php:116
msgid "All properties less or equal to 1000 characters"
msgstr "Propriétés inférieures ou égales à 1000 caractères"

#: src/Form/SettingsFieldset.php:85 src/Form/SettingsFieldset.php:117
msgid "All properties less or equal to 5000 characters"
msgstr "Propriétés inférieures ou égales à 5000 caractères"

#: src/Form/SettingsFieldset.php:86 src/Form/SettingsFieldset.php:112
msgid "All properties more than 500 characters"
msgstr "Propriétés de plus de 500 caractères"

#: src/Form/SettingsFieldset.php:87 src/Form/SettingsFieldset.php:113
msgid "All properties more than 1000 characters"
msgstr "Propriétés de plus de 1000 caractères"

#: src/Form/SettingsFieldset.php:88 src/Form/SettingsFieldset.php:114
msgid "All properties more than 5000 characters"
msgstr "Propriétés de plus de 5000 caractères"

#: src/Form/SettingsFieldset.php:98 src/Form/SettingsFieldset.php:127
msgid "Select properties…"
msgstr "Choisir des propriétés…"

#: src/Form/SettingsFieldset.php:106
msgid "Properties not to translate"
msgstr "Propriétés à ne pas traduire"

#: src/Form/ConfigForm.php:17
msgid "DeepL api key for automatic translation"
msgstr "Clé api DeepL pour la traduction automatique"

#: src/Api/Adapter/TranslationAdapter.php:105
msgid "The translation requires a target language."
msgstr "La traduction nécessite une langue cible."

#: src/Api/Adapter/TranslationAdapter.php:110
msgid "The translation requires a source string."
msgstr "La traduction nécessite une chaîne source."

#: src/Api/Adapter/TranslationAdapter.php:115
msgid "The translation requires a translated string."
msgstr "La traduction nécessite une chaîne traduite."

#: src/Api/Adapter/TranslationAdapter.php:196
msgid ""
"The string \"{string}\", source language \"{language}\" and target language "
"\"{language_2}\" to translate must be unique."
msgstr ""
"La chaîne « {string} », la langue source « {language} » et la langue cible "
"« {language_2} » à traduire doivent être uniques."

